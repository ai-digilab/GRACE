{
    "prefix": "reproduce",
    "dataset": "imagenet100",
    "memory_size": 2000,
    "memory_per_class": 20,
    "fixed_memory": false,
    "shuffle": true,
    "init_cls": 5,
    "increment": 5,
    "model_name": "grace",
    "convnet_type": "resnet18",
    "device": ["0"],
    "seed": [1993],
    "t_base": 0.35,
    "t_decay": 0.9,
    "preservation_exponent": 5,
    "c_kd_factor": 1.2,
    "c_pred_factor": 0.6,
    "pretrain_path": "./pretrained/imagenet100_b5.pt",
    "save_path": "./trained_models"
}
